---
/**
 * Footer Component (i18n-aware)
 * Standard footer for non-landing pages with translated links and labels
 */
import { cn } from '@/lib/cn';
import siteConfig from '@/config/site.config';
import { type Locale, defaultLocale, getLocaleFromPath } from '@/i18n/config';
import { useTranslations, getLocalizedPath } from '@/i18n/index';

interface Props {
  class?: string;
  locale?: Locale;
}

const { class: className, locale: localeProp } = Astro.props;

// Get locale from prop or infer from URL
const locale = localeProp || getLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);

const currentYear = new Date().getFullYear();
---

<footer class={cn('border-t border-border', className)}>
  <div class="container py-16">
    <div class="grid grid-cols-2 gap-8 md:grid-cols-4 lg:grid-cols-5">
      <!-- Brand -->
      <div class="col-span-2 lg:col-span-2">
        <a href={getLocalizedPath('home', locale)} class="inline-flex items-center gap-2 font-semibold text-foreground">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2L2 19.5h20L12 2zm0 4l7 12H5l7-12z" />
          </svg>
          <span>{t('site.name')}</span>
        </a>
        <p class="mt-4 text-sm text-foreground-muted max-w-xs leading-relaxed">
          {t('site.description')}
        </p>

        <!-- Social Links -->
        <div class="mt-6 flex items-center gap-3">
          <a
            href={siteConfig.links.github}
            target="_blank"
            rel="noopener noreferrer"
            class={cn(
              'inline-flex items-center justify-center rounded-md p-2',
              'text-foreground-muted hover:text-foreground hover:bg-secondary',
              'transition-colors'
            )}
            aria-label="GitHub"
          >
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
            </svg>
          </a>
          <a
            href={siteConfig.links.twitter}
            target="_blank"
            rel="noopener noreferrer"
            class={cn(
              'inline-flex items-center justify-center rounded-md p-2',
              'text-foreground-muted hover:text-foreground hover:bg-secondary',
              'transition-colors'
            )}
            aria-label="Twitter"
          >
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Navigation Links -->
      <div>
        <h3 class="text-sm font-semibold text-foreground">{t('nav.home')}</h3>
        <ul class="mt-4 space-y-3">
          <li>
            <a href={getLocalizedPath('home', locale)} class="text-sm text-foreground-muted hover:text-foreground transition-colors">
              {t('nav.home')}
            </a>
          </li>
          <li>
            <a href={getLocalizedPath('blog', locale)} class="text-sm text-foreground-muted hover:text-foreground transition-colors">
              {t('nav.blog')}
            </a>
          </li>
          <li>
            <a href="/rss.xml" class="text-sm text-foreground-muted hover:text-foreground transition-colors inline-flex items-center gap-1">
              <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
              </svg>
              RSS Feed
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-foreground">{t('nav.about')}</h3>
        <ul class="mt-4 space-y-3">
          <li>
            <a href={getLocalizedPath('about', locale)} class="text-sm text-foreground-muted hover:text-foreground transition-colors">
              {t('nav.about')}
            </a>
          </li>
          <li>
            <a href={getLocalizedPath('contact', locale)} class="text-sm text-foreground-muted hover:text-foreground transition-colors">
              {t('nav.contact')}
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-foreground">{t('footer.links.documentation')}</h3>
        <ul class="mt-4 space-y-3">
          <li>
            <a href={siteConfig.links.github} target="_blank" rel="noopener noreferrer" class="text-sm text-foreground-muted hover:text-foreground transition-colors">
              {t('footer.links.github')}
            </a>
          </li>
          <li>
            <a href={siteConfig.links.twitter} target="_blank" rel="noopener noreferrer" class="text-sm text-foreground-muted hover:text-foreground transition-colors">
              {t('footer.links.twitter')}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="mt-16 pt-8 border-t border-border flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-sm text-foreground-muted">
        {t('footer.copyright', { year: currentYear })}
      </p>
      <div class="flex items-center gap-4">
        <a href={siteConfig.links.github} target="_blank" rel="noopener noreferrer" class="text-sm text-foreground-muted hover:text-foreground transition-colors inline-flex items-center gap-1">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
          </svg>
          {t('footer.links.github')}
        </a>
      </div>
    </div>
  </div>
</footer>
