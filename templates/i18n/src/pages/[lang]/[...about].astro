---
/**
 * About page - Localized versions with translated URLs
 *
 * This page generates localized URLs for the about page:
 * - /es/sobre-nosotros (Spanish)
 * - /fr/a-propos (French)
 *
 * The English version is at /about (see src/pages/about.astro)
 */
import LandingLayout from '@/layouts/LandingLayout.astro';
import Icon from '@/components/ui/Icon.astro';
import { locales, isValidLocale, defaultLocale, type Locale } from '@/i18n/config';
import { useTranslations } from '@/i18n/index';
import { routes } from '@/i18n/routes';

export function getStaticPaths() {
  // Generate paths for non-default locales with their translated slugs
  return locales
    .filter((lang) => lang !== defaultLocale)
    .map((lang) => ({
      params: {
        lang,
        about: routes.about[lang], // e.g., 'sobre-nosotros' for Spanish
      },
    }));
}

const { lang } = Astro.params;

if (!lang || !isValidLocale(lang)) {
  return Astro.redirect('/about');
}

const locale = lang as Locale;
const t = useTranslations(locale);
---

<LandingLayout
  title={t('about.meta.title')}
  description={t('about.meta.description')}
  lang={locale}
  routeId="about"
>
  <!-- Hero Section -->
  <section class="relative pt-32 pb-20 overflow-hidden">
    <!-- Background Effects -->
    <div class="absolute inset-0 bg-grid-pattern [mask-image:linear-gradient(to_bottom,white,transparent)] pointer-events-none opacity-30"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-brand-500/8 rounded-full blur-[120px] pointer-events-none"></div>

    <div class="relative mx-auto max-w-4xl px-6 text-center">
      <!-- Badge -->
      <div class="mb-6 inline-flex items-center rounded-full border border-border bg-background px-3 py-1 shadow-sm">
        <span class="flex h-2 w-2 rounded-full bg-brand-500 mr-2 animate-pulse"></span>
        <span class="text-xs font-medium text-foreground-secondary">{t('about.hero.badge')}</span>
      </div>

      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-foreground mb-6">
        {t('about.hero.title')} <span class="text-brand-500">{t('about.hero.titleHighlight')}</span>
      </h1>

      <p class="text-lg text-foreground-muted max-w-2xl mx-auto mb-8 leading-relaxed">
        {t('about.hero.description')}
      </p>
    </div>
  </section>

  <!-- Mission Section -->
  <section class="py-20 bg-surface-secondary">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground mb-6">
        {t('about.mission.title')}
      </h2>
      <p class="text-lg text-foreground-muted max-w-2xl mx-auto leading-relaxed">
        {t('about.mission.description')}
      </p>
    </div>
  </section>

  <!-- Values Section -->
  <section class="py-20">
    <div class="mx-auto max-w-6xl px-6">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground mb-12 text-center">
        {t('about.values.title')}
      </h2>

      <div class="grid gap-8 md:grid-cols-3">
        <!-- Performance -->
        <div class="p-6 rounded-xl border border-border bg-card">
          <div class="w-12 h-12 rounded-lg bg-brand-500/10 flex items-center justify-center mb-4">
            <Icon name="zap" class="w-6 h-6 text-brand-500" />
          </div>
          <h3 class="font-display text-xl font-bold text-foreground mb-2">
            {t('about.values.performance.title')}
          </h3>
          <p class="text-foreground-muted">
            {t('about.values.performance.description')}
          </p>
        </div>

        <!-- Simplicity -->
        <div class="p-6 rounded-xl border border-border bg-card">
          <div class="w-12 h-12 rounded-lg bg-brand-500/10 flex items-center justify-center mb-4">
            <Icon name="box" class="w-6 h-6 text-brand-500" />
          </div>
          <h3 class="font-display text-xl font-bold text-foreground mb-2">
            {t('about.values.simplicity.title')}
          </h3>
          <p class="text-foreground-muted">
            {t('about.values.simplicity.description')}
          </p>
        </div>

        <!-- Open Source -->
        <div class="p-6 rounded-xl border border-border bg-card">
          <div class="w-12 h-12 rounded-lg bg-brand-500/10 flex items-center justify-center mb-4">
            <Icon name="github" class="w-6 h-6 text-brand-500" />
          </div>
          <h3 class="font-display text-xl font-bold text-foreground mb-2">
            {t('about.values.openSource.title')}
          </h3>
          <p class="text-foreground-muted">
            {t('about.values.openSource.description')}
          </p>
        </div>
      </div>
    </div>
  </section>
</LandingLayout>
