    border-bottom: 1px solid var(--border);
    background-color: color-mix(in oklch, var(--background-secondary) 50%, transparent);
    border-radius: 0.75rem 0.75rem 0 0;
  }

  .showcase-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
