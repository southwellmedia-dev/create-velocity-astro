  }

  .showcase-hint {
    font-size: 0.75rem;
    color: var(--foreground-subtle);
  }

  .showcase-content {
    padding: 1.25rem;
    border-radius: 0 0 0.75rem 0.75rem;
    background-color: var(--card);
  }

  /* Hide scrollbar but keep functionality */
  .scrollbar-hide {
