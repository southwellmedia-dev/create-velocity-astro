---
/**
 * Contact page - Default locale (English)
 * URL: /contact
 */
import LandingLayout from '@/layouts/LandingLayout.astro';
import Icon from '@/components/ui/Icon.astro';
import Button from '@/components/ui/Button.astro';
import { Input } from '@/components/ui/Input';
import { Textarea } from '@/components/ui/Textarea';
import { defaultLocale } from '@/i18n/config';
import { useTranslations } from '@/i18n/index';

const locale = defaultLocale;
const t = useTranslations(locale);
---

<LandingLayout
  title={t('contact.meta.title')}
  description={t('contact.meta.description')}
  lang={locale}
  routeId="contact"
>
  <!-- Hero Section -->
  <section class="relative pt-32 pb-20 overflow-hidden">
    <!-- Background Effects -->
    <div class="absolute inset-0 bg-grid-pattern [mask-image:linear-gradient(to_bottom,white,transparent)] pointer-events-none opacity-30"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-brand-500/8 rounded-full blur-[120px] pointer-events-none"></div>

    <div class="relative mx-auto max-w-4xl px-6 text-center">
      <!-- Badge -->
      <div class="mb-6 inline-flex items-center rounded-full border border-border bg-background px-3 py-1 shadow-sm">
        <span class="flex h-2 w-2 rounded-full bg-brand-500 mr-2 animate-pulse"></span>
        <span class="text-xs font-medium text-foreground-secondary">{t('contact.hero.badge')}</span>
      </div>

      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-foreground mb-6">
        {t('contact.hero.title')} <span class="text-brand-500">{t('contact.hero.titleHighlight')}</span>
      </h1>

      <p class="text-lg text-foreground-muted max-w-2xl mx-auto mb-8 leading-relaxed">
        {t('contact.hero.description')}
      </p>
    </div>
  </section>

  <!-- Contact Form Section -->
  <section class="py-20 bg-surface-secondary">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-12 lg:grid-cols-2">
        <!-- Form -->
        <div class="p-8 rounded-xl border border-border bg-card">
          <h2 class="font-display text-2xl font-bold text-foreground mb-6">
            {t('contact.form.title')}
          </h2>

          <form class="space-y-6">
            <Input
              client:visible
              label={t('contact.form.name')}
              placeholder={t('contact.form.namePlaceholder')}
              required
            />

            <Input
              client:visible
              label={t('contact.form.email')}
              type="email"
              placeholder={t('contact.form.emailPlaceholder')}
              required
            />

            <Input
              client:visible
              label={t('contact.form.subject')}
              placeholder={t('contact.form.subjectPlaceholder')}
            />

            <Textarea
              client:visible
              label={t('contact.form.message')}
              placeholder={t('contact.form.messagePlaceholder')}
              rows={5}
              required
            />

            <Button type="submit" class="w-full">
              <Icon name="mail" size="sm" />
              {t('contact.form.submit')}
            </Button>
          </form>
        </div>

        <!-- Contact Info -->
        <div class="flex flex-col justify-center">
          <h2 class="font-display text-2xl font-bold text-foreground mb-8">
            {t('contact.info.title')}
          </h2>

          <div class="space-y-6">
            <!-- Email -->
            <a
              href={`mailto:${t('contact.info.email.value')}`}
              class="flex items-center gap-4 p-4 rounded-lg border border-border bg-card hover:bg-muted transition-colors"
            >
              <div class="w-12 h-12 rounded-lg bg-brand-500/10 flex items-center justify-center">
                <Icon name="mail" class="w-6 h-6 text-brand-500" />
              </div>
              <div>
                <div class="text-sm text-foreground-muted">{t('contact.info.email.label')}</div>
                <div class="font-medium text-foreground">{t('contact.info.email.value')}</div>
              </div>
            </a>

            <!-- GitHub -->
            <a
              href={`https://${t('contact.info.github.value')}`}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-4 p-4 rounded-lg border border-border bg-card hover:bg-muted transition-colors"
            >
              <div class="w-12 h-12 rounded-lg bg-brand-500/10 flex items-center justify-center">
                <Icon name="github" class="w-6 h-6 text-brand-500" />
              </div>
              <div>
                <div class="text-sm text-foreground-muted">{t('contact.info.github.label')}</div>
                <div class="font-medium text-foreground">{t('contact.info.github.value')}</div>
              </div>
            </a>

            <!-- Twitter -->
            <a
              href={`https://twitter.com/${t('contact.info.twitter.value').replace('@', '')}`}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-4 p-4 rounded-lg border border-border bg-card hover:bg-muted transition-colors"
            >
              <div class="w-12 h-12 rounded-lg bg-brand-500/10 flex items-center justify-center">
                <Icon name="twitter" class="w-6 h-6 text-brand-500" />
              </div>
              <div>
                <div class="text-sm text-foreground-muted">{t('contact.info.twitter.label')}</div>
                <div class="font-medium text-foreground">{t('contact.info.twitter.value')}</div>
              </div>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</LandingLayout>
